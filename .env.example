# ---- Database ----
MONGODB_URI=your_mongodb_connection_string_here

# ---- AI (personalization) ----
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Email sending (Gmail SMTP) ----
# Gmail App Password banao: https://myaccount.google.com/apppasswords
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_gmail_app_password
SENDER_NAME=Your Name
SENDER_TITLE=Founder, Your Agency
SENDER_ADDRESS=Your City, Country

# ---- Open tracking + unsubscribe (dashboard deploy URL) ----
# Khali rakho jab tak dashboard deploy na ho. Deploy ke baad uska URL daalo.
TRACK_BASE_URL=

# ---- Telegram notifications (reliable + instant) ----
# Setup: @BotFather -> /newbot -> token | @userinfobot -> chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- WhatsApp notifications (CallMeBot - free, optional backup) ----
# Setup: +34 644 66 32 62 ko WhatsApp pe "I allow callmebot to send me messages" bhejo
WHATSAPP_PHONE=
CALLMEBOT_APIKEY=

# ---- Campaign ----
# NOTE: ab sirf ek hi offer hai — "Digital Presence" agency pitch
# (website redesign + SEO + social media/LinkedIn). CAMPAIGN ka koi asar nahi.
CAMPAIGN=agency
# scraper website-audit: "off" karo to bina audit ke sabki email scrape
AUDIT_MODE=on

# ---- Sending limits (safe defaults) ----
DAILY_SEND_LIMIT=40
MIN_DELAY_SECONDS=45
MAX_DELAY_SECONDS=120
