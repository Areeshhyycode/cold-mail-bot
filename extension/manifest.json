{
  "manifest_version": 3,
  "name": "AI Job Assistant",
  "version": "2.0.0",
  "description": "Jobs scrape karo (30+ fields), AI match-score + missing skills + tailored resume/cover letter lo, sab MongoDB me sync. Human-in-the-loop: apply aap khud karti ho.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "alarms",
    "notifications"
  ],

  "host_permissions": [
    "https://*.indeed.com/*",
    "https://*.linkedin.com/*",
    "https://*.rozee.pk/*",
    "https://boards.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://jobs.ashbyhq.com/*",
    "https://*.workable.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.recruitee.com/*",
    "https://*.bamboohr.com/*",
    "https://*.breezy.hr/*",
    "http://localhost:4000/*",
    "http://127.0.0.1:4000/*"
  ],

  "optional_host_permissions": ["https://*/*"],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.indeed.com/*",
        "https://smartapply.indeed.com/*",
        "https://*.linkedin.com/*"
      ],
      "js": ["autofill-content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["lib/core.js", "lib/extractor.js"],
      "matches": ["https://*.indeed.com/*", "https://*.linkedin.com/*"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'"
  },

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "action": {
    "default_title": "AI Job Assistant",
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
